PORT=5001
DATABASE_URL=postgres://postgres:postgres@localhost:5433/jiva_db
JWT_SECRET=supersecretjivatoken

# ICD-11 lookup (intake questionnaire condition autocomplete).
# Locally deployed WHO ICD-API container — no auth, no rate limits:
#   docker run -d --name jiva-icd-api -p 8382:80 \
#     -e acceptLicense=true -e saveAnalytics=false whoicd/icd-api
# To use WHO's cloud API instead, set ICD_API_BASE=https://id.who.int and
# supply ICD_CLIENT_ID / ICD_CLIENT_SECRET.
ICD_API_BASE=http://localhost:8382
